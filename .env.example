NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=naweririmba

# Session Secret (use a long random string)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Flutterwave Payment Configuration
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-flutterwave-public-key-here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-flutterwave-secret-key-here
FLUTTERWAVE_ENCRYPTION_KEY=your-flutterwave-encryption-key

# App Configuration
APP_NAME=Naweririmba
APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@naweririmba.com

# File Upload Settings
MAX_FILE_SIZE=50MB
UPLOAD_PATH=src/public/uploads

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
