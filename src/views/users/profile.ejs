<div class="container">
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <img src="https://via.placeholder.com/150" class="rounded-circle mb-3" alt="Profile Picture">
                    <h3><%= user.name %></h3>
                    <p class="text-muted"><%= user.email %></p>
                    <p class="text-muted">
                        <i class="bi bi-whatsapp"></i> <%= user.whatsapp %>
                    </p>
                    <p class="text-muted">Member since <%= new Date(user.created_at).toLocaleDateString() %></p>
                </div>
            </div>

            <!-- Wallet Card -->
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-wallet2"></i> My Wallet</h5>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <h3 class="text-success">$<%= parseFloat(user.balance || 0).toFixed(2) %></h3>
                        <p class="text-muted">Available Balance</p>
                        
                        <% if (parseFloat(user.balance || 0) >= 10) { %>
                            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#withdrawModal">
                                <i class="bi bi-cash"></i> Request Withdrawal
                            </button>
                        <% } else { %>
                            <p class="text-muted small">Minimum withdrawal: $10.00</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="card shadow-sm mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <h4><%= userSongs.length %></h4>
                            <p class="text-muted">Songs Uploaded</p>
                        </div>
                        <div class="col-6">
                            <h4><%= soldSongs %></h4>
                            <p class="text-muted">Songs Sold</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#songs">My Songs</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#purchases">My Purchases</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#earnings">Earnings</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#withdrawals">Withdrawals</a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- My Songs Tab -->
                <div class="tab-pane active" id="songs">
                    <div class="row g-4">
                        <% if (userSongs && userSongs.length > 0) { %>
                            <% userSongs.forEach(song => { %>
                                <div class="col-md-6">
                                    <div class="card song-card h-100">
                                        <div class="position-relative">
                                            <img src="/songs/<%= song.id %>/cover" 
                                                 class="card-img-top" alt="<%= song.title %>"
                                                 style="height: 200px; object-fit: cover;"
                                                 onerror="this.src='https://picsum.photos/300/200?random=<%= song.id %>'">
                                        </div>
                                        <div class="card-body">
                                            <h5 class="card-title"><%= song.title %></h5>
                                            <p class="card-text">
                                                <span class="badge bg-primary"><%= song.style %></span>
                                                <span class="badge bg-secondary"><%= song.genre %></span>
                                            </p>
                                            <p class="card-text">
                                                <strong class="price-display" data-price-usd="<%= song.price %>">
                                                    $<%= parseFloat(song.price).toFixed(2) %>
                                                </strong>
                                            </p>
                                            <p class="card-text">
                                                <% if (song.is_sold) { %>
                                                    <span class="badge bg-success">Sold</span>
                                                <% } else { %>
                                                    <span class="badge bg-warning">Available</span>
                                                <% } %>
                                            </p>
                                            <div class="d-flex gap-2">
                                                <a href="/songs/<%= song.id %>" class="btn btn-primary btn-sm">View</a>
                                                <% if (!song.is_sold) { %>
                                                    <a href="/songs/<%= song.id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center">
                                <div class="alert alert-info">
                                    <h5>No songs uploaded yet</h5>
                                    <p>Start sharing your music with the world!</p>
                                    <a href="/songs/upload" class="btn btn-primary">Upload Your First Song</a>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- My Purchases Tab -->
                <div class="tab-pane" id="purchases">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Song</th>
                                    <th>Artist</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (purchases && purchases.length > 0) { %>
                                    <% purchases.forEach(purchase => { %>
                                        <tr>
                                            <td><%= purchase.song_title %></td>
                                            <td><%= purchase.artist_name %></td>
                                            <td>$<%= parseFloat(purchase.amount || 0).toFixed(2) %></td>
                                            <td><%= new Date(purchase.created_at).toLocaleDateString() %></td>
                                            <td>
                                                <a href="/songs/<%= purchase.song_id %>/download" class="btn btn-success btn-sm">
                                                    <i class="bi bi-download"></i> Download
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center">No purchases yet</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Earnings Tab -->
                <div class="tab-pane" id="earnings">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Song</th>
                                    <th>Sale Amount</th>
                                    <th>Commission</th>
                                    <th>Your Earnings</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (earnings && earnings.length > 0) { %>
                                    <% earnings.forEach(earning => { %>
                                        <tr>
                                            <td><%= earning.song_title %></td>
                                            <td>$<%= parseFloat(earning.amount || 0).toFixed(2) %></td>
                                            <td>$<%= parseFloat(earning.commission_amount || 0).toFixed(2) %></td>
                                            <td>$<%= parseFloat(earning.seller_amount || 0).toFixed(2) %></td>
                                            <td><%= new Date(earning.created_at).toLocaleDateString() %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center">No earnings yet</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Withdrawals Tab -->
                <div class="tab-pane" id="withdrawals">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Amount</th>
                                    <th>WhatsApp</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (withdrawals && withdrawals.length > 0) { %>
                                    <% withdrawals.forEach(withdrawal => { %>
                                        <tr>
                                            <td>$<%= parseFloat(withdrawal.amount || 0).toFixed(2) %></td>
                                            <td><%= withdrawal.whatsapp_number %></td>
                                            <td>
                                                <% if (withdrawal.status === 'pending') { %>
                                                    <span class="badge bg-warning">Pending</span>
                                                <% } else if (withdrawal.status === 'approved') { %>
                                                    <span class="badge bg-success">Approved</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Rejected</span>
                                                <% } %>
                                            </td>
                                            <td><%= new Date(withdrawal.created_at).toLocaleDateString() %></td>
                                            <td><%= withdrawal.admin_notes || '-' %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center">No withdrawal requests</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Withdrawal Modal -->
<div class="modal fade" id="withdrawModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Withdrawal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/users/withdraw" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Available Balance</label>
                        <input type="text" class="form-control" value="$<%= parseFloat(user.balance || 0).toFixed(2) %>" disabled>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Withdrawal Amount</label>
                        <input type="number" class="form-control" name="amount" 
                               min="10" max="<%= parseFloat(user.balance || 0) %>" step="0.01" required>
                        <small class="form-text text-muted">Minimum: $10.00</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">WhatsApp Number</label>
                        <input type="tel" class="form-control" name="whatsapp_number" 
                               value="<%= user.whatsapp %>" required>
                        <small class="form-text text-muted">We'll contact you on this number for payment</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Request Withdrawal</button>
                </div>
            </form>
        </div>
    </div>
</div>
